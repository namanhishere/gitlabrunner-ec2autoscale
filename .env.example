# =====================================================================
# GitLab Runner (Docker Autoscaler -> EC2) configuration
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
# =====================================================================

# --- GitLab (self-managed) ---
# Base URL of your self-managed GitLab instance (no trailing slash).
CI_SERVER_URL=https://gitlab.example.com
# Runner authentication token created in GitLab (starts with "glrt-").
# GitLab -> Admin/Group/Project -> CI/CD -> Runners -> New runner.
RUNNER_TOKEN=glrt-XXXXXXXXXXXXXXXXXXXX

# --- AWS credentials for the fleeting plugin ---
# These come from `terraform output` (iam user created for the plugin).
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Autoscaling target ---
# Name of the Auto Scaling Group created by Terraform (`terraform output asg_name`).
ASG_NAME=gitlab-runner-ec2autoscale-asg
# SSH user the AMI exposes (Amazon Linux 2023 -> ec2-user).
SSH_USER=ec2-user
# Default CI image jobs run in (jobs may override via `image:` in .gitlab-ci.yml).
# Keep this in sync with the `ci_image` baked into the AMI by Packer for fast cold starts.
CI_IMAGE=ghcr.io/OWNER/IMAGE:latest

# --- Scaling / behaviour tuning ---
# Total jobs the runner processes in parallel across all instances.
CONCURRENT=10
# Hard ceiling on EC2 instances the plugin may launch (must be <= ASG max_size).
MAX_INSTANCES=10
# Warm idle instances to keep ready for instant pickup (0 = pure on-demand).
IDLE_COUNT=0
# How long an idle instance is kept before being scaled back down.
IDLE_TIME=20m0s
